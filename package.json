{
  "name": "@npm9912/v-map",
  "version": "0.0.1",
  "description": "VMap Components",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/v-map/v-map.esm.js",
  "exports": {
    ".": {
      "import": "./dist/v-map/v-map.esm.js",
      "require": "./dist/v-map/v-map.cjs.js"
    },
    "./v-map-component": {
      "types": "./dist/components/v-map-component.d.ts",
      "import": "./dist/components/v-map-component.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "branches": [
    "main"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pt9912/v-map.git"
  },
  "files": [
    "dist/",
    "dist/v-map",
    "dist/components",
    "loader/"
  ],
  "scripts": {
    "prebuild": "node scripts/gen-versions.mjs",
    "build": "stencil build",
    "build:dev": "cross-env NODE_ENV=development stencil build --dev",
    "typecheck": "tsc --noEmit",
    "docs:stencil": "stencil build --docs",
    "docs:ts": "typedoc",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:build": "pnpm docs:stencil && pnpm docs:ts && pnpm docs:api && vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:pdf": "press-export-pdf export docs",
    "start": "stencil build --dev --watch --serve",
    "test": "pnpm run test:spec && pnpm run test:e2e",
    "test:spec": "stencil test --spec",
    "test:e2e:all:old": "NODE_OPTIONS=--max-old-space-size=7192 stencil test --e2e --logs --max-workers=4",
    "test:e2e": "pnpm run test:e2e:1 && pnpm run test:e2e:2 && pnpm run test:e2e:3 && pnpm run test:e2e:4 && pnpm run test:e2e:5 && pnpm run test:e2e:6 && pnpm run test:e2e:7 && pnpm run test:e2e:8 && pnpm run test:e2e:9 && pnpm run test:e2e:10 && pnpm run test:e2e:11",
    "test:e2e:1": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map/v-map.e2e.ts src/components/v-map-layer-xyz/v-map-layer-xyz.e2e.ts src/components/v-map-layer-wms/v-map-layer-wms.e2e.ts src/components/v-map-layer-wkt/v-map-layer-wkt.e2e.ts src/components/v-map-layer-geojson/v-map-layer-geojson.e2e.ts src/components/v-map-layer-scatterplot/v-map-layer-scatterplot.e2e.ts src/components/v-map-layer-tile3d/v-map-layer-tile3d.e2e.ts",
    "test:e2e:2": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-google/v-map-layer-google-basics.e2e.ts",
    "test:e2e:3": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-style/v-map-style-wkt.e2e.ts",
    "test:e2e:4": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-osm/v-map-layer-osm.e2e.ts src/components/v-map-layer-wfs/v-map-layer-wfs.e2e.ts",
    "test:e2e:5": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layergroup/v-map-layergroup.e2e.ts src/components/v-map-layercontrol/v-map-layercontrol.e2e.ts",
    "test:e2e:6": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-geotiff/v-map-layer-geotiff.e2e.ts src/components/v-map-layer-wcs/v-map-layer-wcs.e2e.ts",
    "test:e2e:7": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-terrain/v-map-layer-terrain.e2e.ts src/components/v-map-builder/v-map-builder.e2e.ts",
    "test:e2e:8": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-google/v-map-layer-google-properties.e2e.ts src/components/v-map-layer-google/v-map-layer-google-advanced.e2e.ts",
    "test:e2e:9": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-style/v-map-style-geojson.e2e.ts",
    "test:e2e:10": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-style/v-map-style-advanced.e2e.ts",
    "test:e2e:11": "NODE_OPTIONS=--max-old-space-size=7192 pnpm stencil test --e2e --logs -- src/components/v-map-layer-terrain-geotiff/v-map-layer-terrain-geotiff.e2e.ts",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "storybook-reset": "node scripts/clean-storybook-cache.mjs && storybook dev -p 6006 --no-open",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:with-build": "pnpm run build && pnpm run storybook",
    "build-storybook": "storybook build"
  },
  "pnpm": {
    "overrides": {
      "@docsearch/react": "4.0.0-beta.8",
      "@docsearch/js": "4.0.0-beta.8",
      "@docsearch/css": "4.0.0-beta.8"
    }
  },
  "peerDependencies": {
    "@deck.gl/core": "^9.2.0",
    "@deck.gl/extensions": "^9.2.0",
    "@deck.gl/geo-layers": "^9.2.0",
    "@deck.gl/json": "^9.2.0",
    "@deck.gl/layers": "^9.2.0",
    "@deck.gl/mesh-layers": "^9.2.0",
    "cesium": "^1.133",
    "leaflet": "^1.9",
    "ol": "^10.6"
  },
  "peerDependenciesMeta": {
    "ol": {
      "optional": true
    },
    "leaflet": {
      "optional": true
    },
    "cesium": {
      "optional": true
    }
  },
  "dependencies": {
    "@mapbox/martini": "^0.2.0",
    "@types/leaflet": "^1.9.21"
  },
  "devDependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/extensions": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/json": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mesh-layers": "^9.2.11",
    "@docsearch/js": "4.0.0-beta.8",
    "@docsearch/react": "4.0.0-beta.8",
    "@gisatcz/deckgl-geolib": "^2.3.0",
    "@loaders.gl/3d-tiles": "^4.3.4",
    "@loaders.gl/core": "^4.3.4",
    "@loaders.gl/gis": "^4.3.4",
    "@loaders.gl/gltf": "^4.3.4",
    "@loaders.gl/images": "^4.3.4",
    "@loaders.gl/loader-utils": "4.3.4",
    "@loaders.gl/mvt": "^4.3.4",
    "@loaders.gl/schema": "^4.3.4",
    "@loaders.gl/terrain": "^4.3.4",
    "@loaders.gl/tiles": "^4.3.4",
    "@loaders.gl/wms": "^4.3.4",
    "@luma.gl/core": "^9.2.6",
    "@math.gl/core": "^4.1.0",
    "@npm9912/s-gml": "^1.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^10.0.5",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@stencil/core": "^4.43.3",
    "@stencil/storybook-plugin": "0.4.2",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-links": "^9.1.7",
    "@storybook/addon-onboarding": "^9.1.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@ungap/global-this": "^0.4.4",
    "@vitest/ui": "^2.1.1",
    "caniuse-lite": "^1.0.30001741",
    "cesium": "^1.139.1",
    "cross-env": "^10.0.0",
    "fast-xml-parser": "5.5.9",
    "georaster": "1.6.0",
    "georaster-layer-for-leaflet": "4.1.2",
    "geostyler-lyrx-parser": "^1.4.0",
    "geostyler-mapbox-parser": "^6.2.0",
    "geostyler-qgis-parser": "^4.1.0",
    "geostyler-sld-parser": "^8.4.1",
    "geostyler-style": "^11.0.2",
    "geotiff": "3.0.5",
    "geotiff-geokeys-to-proj4": "^2024.4.13",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.0.0",
    "leaflet": "^1.9.4",
    "memfs": "^4.57.1",
    "ol": "^10.8.0",
    "proj4": "^2.20.4",
    "puppeteer": "^24.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "semantic-release": "^24.0.0",
    "snap-bbox": "^0.5.0",
    "storybook": "^9.1.7",
    "tiff-imagery-provider": "^2.17.1",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.8.1",
    "uuid": "^13.0.0",
    "vite": "^7.1.7",
    "vitepress": "^1.6.4",
    "vitepress-export-pdf": "^1.0.0",
    "vitest": "^2.1.1",
    "wellknown": "^0.5.0"
  },
  "license": "MIT"
}
