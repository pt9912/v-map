{
  "name": "@pt9912/v-map",
  "version": "0.0.1",
  "description": "VMap Components",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/v-map/v-map.esm.js",
  "exports": {
    ".": {
      "import": "./dist/v-map/v-map.esm.js",
      "require": "./dist/v-map/v-map.cjs.js"
    },
    "./v-map-component": {
      "types": "./dist/components/v-map-component.d.ts",
      "import": "./dist/components/v-map-component.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "branches": [
    "main"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pt9912/v-map.git"
  },
  "files": [
    "dist/",
    "dist/v-map",
    "dist/components",
    "loader/"
  ],
  "scripts": {
    "prebuild": "node scripts/gen-versions.mjs",
    "build": "stencil build",
    "build:dev": "cross-env NODE_ENV=development stencil build --dev",
    "docs:stencil": "stencil build --docs",
    "docs:ts": "typedoc",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:build": "pnpm docs:stencil && pnpm docs:ts && pnpm docs:api && vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:pdf": "press-export-pdf export docs",
    "start": "stencil build --dev --watch --serve",
    "test": "pnpm run test:spec && pnpm run test:e2e",
    "test:spec": "stencil test --spec",
    "test:e2e": "stencil test --e2e --logs",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "storybook": "pnpm run build && storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "pnpm": {
    "overrides": {
      "@docsearch/react": "4.0.0-beta.8",
      "@docsearch/js": "4.0.0-beta.8",
      "@docsearch/css": "4.0.0-beta.8"
    }
  },
  "peerDependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/json": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "cesium": "^1.133",
    "leaflet": "^1.9",
    "ol": "^10.6"
  },
  "peerDependenciesMeta": {
    "ol": {
      "optional": true
    },
    "leaflet": {
      "optional": true
    },
    "cesium": {
      "optional": true
    }
  },
  "devDependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/json": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@docsearch/js": "4.0.0-beta.8",
    "@docsearch/react": "4.0.0-beta.8",
    "@loaders.gl/core": "^4.3.4",
    "@loaders.gl/gltf": "^4.3.4",
    "@loaders.gl/loader-utils": "4.3.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^10.0.5",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@stencil/core": "^4.37.1",
    "@stencil/storybook-plugin": "0.4.2",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-links": "^9.1.7",
    "@storybook/addon-onboarding": "^9.1.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@ungap/global-this": "^0.4.4",
    "@vitest/ui": "^2.1.1",
    "caniuse-lite": "^1.0.30001741",
    "cesium": "^1.133.1",
    "cross-env": "^10.0.0",
    "georaster": "1.6.0",
    "georaster-layer-for-leaflet": "4.1.2",
    "geostyler-lyrx-parser": "^1.2.0",
    "geostyler-mapbox-parser": "^6.1.1",
    "geostyler-qgis-parser": "^4.0.2",
    "geostyler-sld-parser": "^8.1.0",
    "geostyler-style": "^10.5.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.0.0",
    "leaflet": "^1.9.4",
    "memfs": "^4.48.1",
    "ol": "^10.6.1",
    "puppeteer": "^24.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "semantic-release": "^24.0.0",
    "storybook": "^9.1.7",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.8.1",
    "vite": "^7.1.7",
    "vitepress": "^1.6.4",
    "vitepress-export-pdf": "^1.0.0",
    "vitest": "^2.1.1"
  },
  "license": "MIT",
  "dependencies": {
    "leaflet.gridlayer.googlemutant": "^0.15.0"
  }
}
